# LIFF アプリの ID（LINE Developers > LINEログインチャネル > LIFF タブで発行）
NEXT_PUBLIC_LIFF_ID=1234567890-abcdefgh

# LINEログインチャネルのチャネルID（IDトークン検証に使用）
LINE_LOGIN_CHANNEL_ID=1234567890

# Messaging API チャネルのチャネルアクセストークン（リッチメニュー設定・友だち判定に使用）
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxx

# 公式アカウントの友だち追加 URL（LINE公式アカウントマネージャーで確認できる lin.ee の URL、
# または https://line.me/R/ti/p/@ベーシックID 形式。ギフト受け取り画面の「友だち追加」ボタンに使用）
NEXT_PUBLIC_OA_ADD_FRIEND_URL=https://lin.ee/xxxxxxx

# このアプリ自身が外部から到達可能な公開 URL（末尾スラッシュなし）。
# 開発中は ngrok の固定ドメイン、本番はデプロイ先のドメインを設定する。
# OGP のサムネイル画像・シェア時の Flex メッセージの hero image 生成に使用。
# 未設定だと OGP プレビューと Flex サムネイルは表示されない（他の機能には影響しない）。
NEXT_PUBLIC_APP_URL=https://xxxx-yyyy.ngrok-free.dev

# SQLite データベース（開発用はこのままで OK）
DATABASE_URL="file:./dev.db"
